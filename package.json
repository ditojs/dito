{
  "name": "dito",
  "private": true,
  "type": "module",
  "description": "Dito.js is a declarative and modern web framework with a focus on API driven development, based on Koa.js, Objection.js and Vue.js",
  "repository": "https://github.com/ditojs/dito",
  "author": "Jürg Lehni <juerg@scratchdisk.com> (http://scratchdisk.com)",
  "license": "MIT",
  "scripts": {
    "clean": "pnpm -r run clean",
    "build": "pnpm -r run build",
    "watch": "pnpm -r --parallel run watch",
    "prepublishOnly": "pnpm run lint",
    "version": "pnpm install && git stage pnpm-lock.yaml",
    "postinstall": "husky",
    "publish": "npm login && lerna publish",
    "test": "vitest",
    "test:types": "vitest --typecheck.only",
    "eslint": "NODE_ENV=production eslint packages/*/src packages/*/types",
    "eslint:fix": "pnpm run eslint --fix",
    "stylelint": "stylelint packages/*/src/**/*.{vue,scss}",
    "stylelint:fix": "pnpm run stylelint --fix",
    "penere": "penere packages/*/src/**/*.{js,vue} packages/*/types/**/*.ts --check",
    "penere:fix": "penere packages/*/src/**/*.{js,vue} packages/*/types/**/*.ts --write",
    "lint": "concurrently pnpm:eslint pnpm:penere pnpm:stylelint",
    "lint:fix": "pnpm run eslint:fix && pnpm run penere:fix && pnpm run stylelint:fix",
    "update": "pnpm update -r --interactive --latest",
    "update:sync": "pnpm update -r",
    "link:all": "node packages/build/src/cli/pnpm-link.js knex objection",
    "unlink:all": "node packages/build/src/cli/pnpm-unlink.js knex objection"
  },
  "lint-staged": {
    "packages/**/src/**/*.{js,ts}": [
      "env NODE_ENV=production eslint --max-warnings 0"
    ],
    "packages/**/src/**/*.vue": [
      "env NODE_ENV=production eslint --max-warnings 0",
      "stylelint"
    ],
    "packages/**/src/**/*.scss": [
      "stylelint"
    ]
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "devDependencies": {
    "@prettier/plugin-pug": "^3.4.2",
    "@typescript-eslint/parser": "^8.57.0",
    "@volar/language-service": "^2.4.28",
    "@vue/language-plugin-pug": "^3.2.5",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vue-pug": "1.0.0-alpha.5",
    "full-icu": "^1.5.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.6",
    "lint-staged": "^16.3.3",
    "prettier": "npm:penere@^3.6.2",
    "stylelint": "^17.4.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.0.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-eslint-parser-template-tokenizer-pug": "^1.0.0"
  },
  "packageManager": "pnpm@10.6.2"
}
